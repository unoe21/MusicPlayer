<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayer.MVVM.ViewModel"
        xmlns:model="clr-namespace:MusicPlayer.MVVM.Model"
        d:DataContext="{d:DesignInstance Type=model:Track}"
        mc:Ignorable="d"
        Title="MusicPlayer"
        Height="700" Width="1050"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <!--Main colors= #091d38 (blue), #fc3c44 (coral)-->

    <Border Background="#091d38" CornerRadius="25" MouseDown="Border_MouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            
            <!--Menu-->
            <Border Background="#091d38" CornerRadius="25 0 0 25" Grid.RowSpan="2">
                <StackPanel Margin="0 30 0 0">
                    <!--Ellipses-->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="30 0 0 0">
                        <Ellipse Fill="#ff605c" Width="12" Height="12" MouseDown="Ellipse_MouseDown_Red"/>
                        <Ellipse Fill="#ffbd44" Width="12" Height="12" Margin="7 0" MouseDown="Ellipse_MouseDown_Yellow"/>
                        <Ellipse Fill="#00ca4e" Width="12" Height="12" MouseDown="Ellipse_MouseDown_Green"/>
                    </StackPanel>

                    <TextBlock Text="LIBRARY" Style="{StaticResource menuTitle}"/>

                    <Button Name="Home"  Style="{StaticResource menuButton}" Click="MenuButton_Click">
                        <Grid>
                            <TextBlock Text="Home" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                    <Button Name="Playlists"  Style="{StaticResource menuButton}" Click="MenuButton_Click">
                        <Grid>
                            <TextBlock Text="Playlists" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                    <Button Name="Artists" Style="{StaticResource menuButton}" Click="MenuButton_Click">
                        <Grid>
                            <TextBlock Text="Artists" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                    <Button Name="Albums" Style="{StaticResource menuButton}" Click="MenuButton_Click">
                        <Grid>
                            <TextBlock Text="Albums" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                    <Button Name="Songs" Style="{StaticResource menuButton}" Click="MenuButton_Click">
                        <Grid>
                            <TextBlock Text="Songs" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                    <TextBlock Text="DISCOVER" Style="{StaticResource menuTitle}"/>
                    
                    <Button Style="{StaticResource menuButton}" Command="{Binding OpenFileCommand}">
                        <Grid>
                            <TextBlock Text="Search" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>
                    
                    <Button Style="{StaticResource menuButton}">
                        <Grid>
                            <TextBlock Text="Radio" Margin="0 0 0 2"/>
                            <Icon:PackIconMaterial Style="{StaticResource meanuButtonIcon}"/>
                        </Grid>
                    </Button>

                </StackPanel>
            </Border>
            
            <!--Music Section-->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>

            <!--Player-->
            <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Background="#fc3c44" CornerRadius="40 0 40 0" Margin="40 0 0 0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="60" Height="60" Margin="30 0 0 0">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding CoverImage}"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20 0 30 0">
                        <ScrollViewer Name="artistScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Width="100">
                            <TextBlock x:Name="artist_name" Text="{Binding Artist}" Foreground="White" FontSize="22" FontWeight="Bold">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="artist_translateTransform" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </ScrollViewer>

                        <ScrollViewer Name="musicScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Width="100">
                            <TextBlock x:Name="music_name" Text="{Binding Title}" Foreground="White" FontSize="18" FontWeight="SemiBold">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="music_translateTransform" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Előző szám gomb -->
                    <Button Command="{Binding PreviousTrackCommand}" Style="{StaticResource playerButton}">
                        <Icon:PackIconMaterial Kind="SkipPrevious" Style="{StaticResource playerButtonIcon}"/>
                    </Button>

                    <!-- Lejátszás / Szünet gomb -->
                    <Button Command="{Binding PlayPauseCommand}" Style="{StaticResource playerButton}">
                        <Icon:PackIconMaterial x:Name="PlayPauseIcon" Kind="{Binding PlayPauseIconKind}" Style="{StaticResource playerButtonIcon}"/>
                    </Button>

                    <!-- Következő szám gomb -->
                    <Button Command="{Binding NextTrackCommand}" Style="{StaticResource playerButton}">
                        <Icon:PackIconMaterial Kind="SkipNext" Style="{StaticResource playerButtonIcon}"/>
                    </Button>

                    <Slider x:Name="ProgressSlider"
                            Minimum="0"
                            Maximum="{Binding CurrentTrackDurationSeconds}"
                            Value="{Binding CurrentPositionSeconds, Mode=TwoWay}"
                            PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                            PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                            Style="{DynamicResource SliderStyle1}"
                            IsSelectionRangeEnabled="True" VerticalAlignment="Center" 
                            Width="350"
                            SelectionEnd="{Binding ElementName=slider,Path=Value}"/>

                    <Button Style="{StaticResource playerButton}">
                        <Icon:PackIconMaterial Kind="VolumeHigh" Style="{StaticResource playerButtonIcon}"/>
                    </Button>

                </StackPanel>
                
            </Border>
        
        </Grid>
    </Border>
</Window>
