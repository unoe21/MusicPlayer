<UserControl x:Class="MusicPlayer.MVVM.View.AlbumsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayer.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Grid.Column="1" Background="#091d38" Margin="40 58 40 0">
            <TextBlock Text="Albums" Style="{StaticResource titleText}" Margin="10"/>

            <ScrollViewer Height="400" VerticalScrollBarVisibility="Hidden">

                <ListBox ItemsSource="{Binding Albums}" 
                         SelectedItem="{Binding SelectedAlbum, Mode=TwoWay}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" Margin="10" Width="200">
                                <Grid Width="200" Height="200">

                                    <Border Width="200" Height="200" BorderBrush="Transparent" BorderThickness="5" CornerRadius="20">
                                        <Border.Effect>
                                            <DropShadowEffect 
                                                BlurRadius="20"
                                                Color="black"
                                                Opacity="0.8"/>
                                        </Border.Effect>

                                        <Image Width="170" Height="170" Source="{Binding CoverImage}" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,170,170" RadiusX="20" RadiusY="20"/>
                                            </Image.Clip>
                                        </Image>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{Binding Name}" 
                                           Foreground="White" FontSize="16" FontWeight="SemiBold" 
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           Margin="0 10 0 0" TextTrimming="CharacterEllipsis"/>

                                <TextBlock Text="{Binding Artist}" 
                                           Foreground="LightGray" FontSize="14" 
                                           HorizontalAlignment="Center" TextAlignment="Center"
                                           Margin="0 3 0 0" TextTrimming="CharacterEllipsis"/>

                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>