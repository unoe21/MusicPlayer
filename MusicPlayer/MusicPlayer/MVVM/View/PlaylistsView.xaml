<UserControl x:Class="MusicPlayer.MVVM.View.PlaylistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MusicPlayer.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Grid.Column="1" Background="#091d38" Margin="40 58 40 0">
            <TextBlock Text="Playlists" Style="{StaticResource titleText}"/>

            <!-- Gomb balra zárva -->
            <Grid Margin="20,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="20">
                    <Grid Width="200" Height="200">
                        <Border Width="200" Height="200" BorderBrush="Transparent" BorderThickness="5" CornerRadius="20">
                            <Border.Effect>
                                <DropShadowEffect 
                                    BlurRadius="20"
                                    Color="black"
                                    Opacity="0.8"/>
                            </Border.Effect>

                            <Grid Background="#fc3c44" Width="170" Height="170" Cursor="Hand">
                                <Grid.Clip>
                                    <RectangleGeometry Rect="0,0,170,170" RadiusX="20" RadiusY="20"/>
                                </Grid.Clip>
                                <TextBlock Text="+" 
                                           Foreground="White" 
                                           FontSize="72" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           FontWeight="Bold"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
